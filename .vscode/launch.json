{
  "version": "0.2.0",
  "configurations": [
    {
      "name": "Launch Vite Frontend",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/octofit-tracker/frontend",
      "runtimeExecutable": "npm",
      "runtimeArgs": [
        "run",
        "dev",
        "--",
        "--host",
        "0.0.0.0"
      ],
      "port": 5173,
      "env": {
        "VITE_CODESPACE_NAME": "${env:CODESPACE_NAME}"
      }
    },
    {
      "name": "Launch Backend",
      "type": "pwa-node",
      "request": "launch",
      "cwd": "${workspaceFolder}/octofit-tracker/backend",
      "runtimeExecutable": "npm",
      "runtimeArgs": ["run", "dev"],
      "console": "integratedTerminal",
      "env": {
        "PORT": "8000"
      }
    }
  ]
}
